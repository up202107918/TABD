etl/data/caop/**/*.dbf
etl/data/caop/**/*.shx
etl/data/caop/**/*.prj
!etl/data/downloads/.gitkeep
!etl/data/extracted/.gitkeep
!etl/data/processed/.gitkeep
!etl/data/logs/.gitkeep

