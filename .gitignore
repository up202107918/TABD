# Data files (too large for Git; regenerate via ETL or manual download)
data/downloads/*
data/extracted/*
data/processed/*
data/logs/*.log
!data/downloads/.gitkeep
!data/extracted/.gitkeep
!data/processed/.gitkeep

etl/data/downloads/*
etl/data/extracted/*
etl/data/processed/*
etl/data/logs/*.log
