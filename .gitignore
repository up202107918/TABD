!data/extracted/.gitkeep
!data/processed/.gitkeep

etl/data/downloads/*
etl/data/extracted/*
etl/data/processed/*
etl/data/logs/*.log
!etl/data/downloads/.gitkeep
!etl/data/extracted/.gitkeep
!etl/data/processed/.gitkeep
!etl/data/logs/.gitkeep

